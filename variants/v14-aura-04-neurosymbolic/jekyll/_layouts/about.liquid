---
layout: default
---

{% comment %}
  AURA Lab — Variant v14 — aura-04-neurosymbolic
  Spec / Prose Pairs layout. Every claim is paired with a typed
  predicate on the left and prose on the right; a phosphor-green ⊢
  sits in the gutter. Hard-inherits v02 visual DNA.
{% endcomment %}

<main class="shell">
  <section class="win" aria-label="AURA Lab spec terminal">

    <header class="win__bar">
      <span class="win__dots" aria-hidden="true">[ x ][ - ][ + ]</span>
      <span class="win__title">aura-se-lab.github.io / tty4 / spec.aura</span>
      <span class="win__meta">William &amp; Mary &middot; Dept. of Computer Science</span>
    </header>

    <div class="win__body">

      <div class="prompt">
        <span class="ps1">aura-se-lab:~/$</span>
        <span class="cmd">load</span>
        <span class="arg">spec.aura --check</span>
      </div>

      <pre class="logo" aria-label="AURA Lab" role="img"><span class="logo__glow"> █████  ██    ██ ██████   █████
██   ██ ██    ██ ██   ██ ██   ██
███████ ██    ██ ██████  ███████
██   ██ ██    ██ ██   ██ ██   ██
██   ██  ██████  ██   ██ ██   ██</span>
<span class="logo__rule">────────────────────────────────────────────</span>
<span class="logo__sub">// LAB · {{ site.affiliation | default: "WILLIAM & MARY" | upcase }} · SINCE 2024 · spec/prose pairs</span></pre>

      <h1 class="h1">
        The <span class="acro">A</span><span>URA</span> Lab<span class="cursor" aria-hidden="true">&nbsp;</span>
      </h1>

      <p class="tagline">
        <span class="acro">(A)</span>I for
        <span class="acro">(U)</span>nderstandable and
        <span class="acro">(R)</span>esponsible
        <span class="acro">(A)</span>utomation in Software Engineering.
      </p>

      <dl class="facts">
        <dt>Director</dt>     <dd>Dr. Antonio Mastropaolo &middot; Assistant Professor</dd>
        <dt>Institution</dt>  <dd>William &amp; Mary &middot; Department of Computer Science</dd>
        <dt>Founded</dt>      <dd>Fall 2024</dd>
        <dt>Contact</dt>      <dd>{{ site.email | default: "amastropaolo at wm dot edu" }}</dd>
        <dt>Director site</dt><dd><a href="https://antoniomastropaolo.com">antoniomastropaolo.com</a></dd>
      </dl>

      {% comment %} ── Body content from the page itself (markdown w/ pair shortcodes) ── {% endcomment %}
      {{ content }}

      <hr class="rule" aria-hidden="true" />
      <div class="prompt" style="margin-top:10px;">
        <span class="ps1">aura-se-lab:~/$</span>
        <span class="cmd">qed</span>
        <span class="arg">--exit 0</span>
      </div>
      <div class="sig">
        <div>
          mailto:&nbsp;<a href="mailto:{{ site.email | default: 'amastropaolo@wm.edu' }}">{{ site.email | default: 'amastropaolo@wm.edu' }}</a>
          &nbsp;&middot;&nbsp;
          web:&nbsp;<a href="{{ site.url | default: 'https://aura-se-lab.github.io' }}">aura-se-lab.github.io</a>
        </div>
        <div class="sig__hint">// ⊢ spec entails prose &middot; end of file</div>
      </div>

    </div>
  </section>
</main>
