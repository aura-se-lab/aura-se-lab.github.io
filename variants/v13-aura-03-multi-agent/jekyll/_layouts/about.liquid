---
# Jekyll layout for AURA Lab homepage — variant v13 (aura-03-multi-agent)
# Drop into _layouts/about.liquid in the al-folio site. Pairs with
# _sass/_variant.scss imported from assets/css/main.scss.
layout: default
---

{% assign lab_name        = site.data.lab.name        | default: "The AURA Lab" %}
{% assign lab_tagline     = site.data.lab.tagline     | default: "AI for Understandable and Responsible Automation in Software Engineering." %}
{% assign lab_director    = site.data.lab.director    | default: "Dr. Antonio Mastropaolo" %}
{% assign lab_institution = site.data.lab.institution | default: "William & Mary · Department of Computer Science" %}
{% assign lab_founded     = site.data.lab.founded     | default: "Fall 2024" %}
{% assign lab_contact     = site.data.lab.contact     | default: "amastropaolo at wm dot edu" %}

<main class="v13 shell">
  <section class="win" aria-label="AURA Lab terminal — agent transcript">

    <header class="win__bar">
      <span class="win__dots" aria-hidden="true">[ x ][ - ][ + ]</span>
      <span class="win__title">aura-se-lab.github.io / tty3 / agents.log</span>
      <span class="win__meta">{{ lab_institution }}</span>
    </header>

    <div class="win__body">

      <div class="prompt">
        <span class="ps1">aura-se-lab:~/$</span>
        <span class="cmd">tail -f</span>
        <span class="arg">agents.log</span>
      </div>

      <pre class="logo" aria-label="AURA Lab" role="img">
<span class="logo__glow"> █████  ██    ██ ██████   █████
██   ██ ██    ██ ██   ██ ██   ██
███████ ██    ██ ██████  ███████
██   ██ ██    ██ ██   ██ ██   ██
██   ██  ██████  ██   ██ ██   ██</span>
<span class="logo__rule">────────────────────────────────────────────</span>
<span class="logo__sub">// LAB · WILLIAM &amp; MARY · SINCE 2024 · MULTI-AGENT RENDER</span></pre>

      <h1 class="h1">
        The <span class="acro">A</span><span>URA</span> Lab<span class="cursor" aria-hidden="true">&nbsp;</span>
      </h1>

      <p class="tagline">
        <span class="acro">(A)</span>I for
        <span class="acro">(U)</span>nderstandable and
        <span class="acro">(R)</span>esponsible
        <span class="acro">(A)</span>utomation in Software Engineering.
      </p>

      <dl class="facts">
        <dt>Director</dt>     <dd>{{ lab_director }} · Assistant Professor</dd>
        <dt>Institution</dt>  <dd>{{ lab_institution }}</dd>
        <dt>Founded</dt>      <dd>{{ lab_founded }}</dd>
        <dt>Contact</dt>      <dd>{{ lab_contact }}</dd>
        <dt>Director site</dt><dd><a href="https://antoniomastropaolo.com">antoniomastropaolo.com</a></dd>
      </dl>

      <div class="pipeline" aria-label="Render pipeline: four named agents">
        <span class="pipeline__label">render pipeline</span>
        <span class="chip chip--planner">planner</span>
        <span class="pipeline__arrow">→</span>
        <span class="chip chip--coder">coder</span>
        <span class="pipeline__arrow">→</span>
        <span class="chip chip--tester">tester</span>
        <span class="pipeline__arrow">→</span>
        <span class="chip chip--reviewer">reviewer</span>
        <span class="pipeline__arrow">·</span>
        <span class="pipeline__label">role-aligned · coordinated · end-to-end</span>
      </div>

      {% comment %}
        Each section is a "loop": transcript (left) + content (right).
        Render the actual page body inside {{ content }} *after* the
        canonical sections below — this layout intentionally owns the
        sections so the agent-transcript framing stays consistent.
      {% endcomment %}

      <div class="stack" role="list">

        {%- comment -%} ───── 01 MISSION ───── {%- endcomment -%}
        <article class="loop" id="loop-mission" role="listitem">
          <aside class="tx" aria-label="Agent transcript: mission">
            <div class="tx__head">// loop 01 · agents.log</div>
            <span class="tx__line"><span class="tx__t">[t+0.04s][a01]</span> <span class="tx__role tx__role--planner">[planner]</span> <span class="tx__msg">plan(homepage.mission): render lab statement verbatim.</span></span>
            <span class="tx__line"><span class="tx__t">[t+0.08s][a02]</span> <span class="tx__role tx__role--coder">[coder]</span> <span class="tx__msg">writing 91 words from _content.md §lab-statement…</span></span>
            <span class="tx__line"><span class="tx__t">[t+0.12s][a03]</span> <span class="tx__role tx__role--tester">[tester]</span> <span class="tx__msg"><span class="ok">✓</span> canonical content matches target (1/1 statement rendered).</span></span>
            <span class="tx__line"><span class="tx__t">[t+0.16s][a04]</span> <span class="tx__role tx__role--reviewer">[reviewer]</span> <span class="tx__msg">no rewrite; tone preserved; cite Fall 2024.</span></span>
            <span class="tx__stamp">approved</span>
          </aside>
          <div class="con">
            <div class="section__head">
              <span class="section__nav"><span class="ps1">&gt; aura_lab ::</span> <span class="cmd">cat</span> <span class="arg">$about.md</span></span>
              <span class="section__tag">// 01 — mission</span>
            </div>
            <h2 class="h2" id="mission-h">Mission</h2>
            <p class="pull">
              {{ site.data.lab.statement | default: "The AURA Lab, founded in Fall 2024, advances research at the intersection of efficiency, automation, and explainability in software engineering. Our mission is to design innovative and responsible AI-driven solutions that improve developer productivity while addressing key challenges of transparency and resource efficiency. Through rigorous methods, open collaboration, and a commitment to impactful work, the AURA Lab contributes practical advances in AI-supported software engineering for academia, industry, and society." }}
            </p>
          </div>
        </article>

        {%- comment -%} ───── 02 RESEARCH AVENUES ───── {%- endcomment -%}
        {% assign avenues = site.data.lab.avenues %}
        <article class="loop" id="loop-research" role="listitem">
          <aside class="tx" aria-label="Agent transcript: research avenues">
            <div class="tx__head">// loop 02 · agents.log</div>
            <span class="tx__line"><span class="tx__t">[t+0.21s][a01]</span> <span class="tx__role tx__role--planner">[planner]</span> <span class="tx__msg">plan(research): enumerate 4 primary + 1 supporting avenue.</span></span>
            <span class="tx__line"><span class="tx__t">[t+0.27s][a02]</span> <span class="tx__role tx__role--coder">[coder]</span> <span class="tx__msg">emit grid: explainability, efficiency, multi-agent, neurosymbolic, task-aware.</span></span>
            <span class="tx__line"><span class="tx__t">[t+0.34s][a03]</span> <span class="tx__role tx__role--tester">[tester]</span> <span class="tx__msg"><span class="ok">✓</span> {{ avenues | size | default: 5 }}/5 avenues present; primary=4, supporting=1.</span></span>
            <span class="tx__line"><span class="tx__t">[t+0.40s][a04]</span> <span class="tx__role tx__role--reviewer">[reviewer]</span> <span class="tx__msg">ordering matches canonical; "multi-agent" highlighted (this page).</span></span>
            <span class="tx__stamp">approved</span>
          </aside>
          <div class="con">
            <div class="section__head">
              <span class="section__nav"><span class="ps1">&gt; aura_lab ::</span> <span class="cmd">ls</span> <span class="arg">research/</span></span>
              <span class="section__tag">// 02 — research avenues</span>
            </div>
            <h2 class="h2" id="research-h">Research Avenues</h2>
            <div class="avenues">
              {% for a in avenues %}
                <article class="avenue {% if a.supporting %}avenue--sub{% endif %}">
                  <div class="avenue__no">{% if a.supporting %}[+1] supporting direction{% else %}[{{ forloop.index | prepend: "0" | slice: -2, 2 }}]{% endif %}</div>
                  <h3 class="avenue__title">{{ a.title }}</h3>
                  <p class="avenue__body">{{ a.body }}</p>
                </article>
              {% endfor %}
            </div>
          </div>
        </article>

        {%- comment -%} ───── 03 PUBLICATIONS ───── {%- endcomment -%}
        {% assign pubs = site.data.lab.publications %}
        <article class="loop" id="loop-pubs" role="listitem">
          <aside class="tx" aria-label="Agent transcript: publications">
            <div class="tx__head">// loop 03 · agents.log</div>
            <span class="tx__line"><span class="tx__t">[t+0.46s][a01]</span> <span class="tx__role tx__role--planner">[planner]</span> <span class="tx__msg">plan(pubs): render selected pubs as BibTeX; venue+year.</span></span>
            <span class="tx__line"><span class="tx__t">[t+0.55s][a02]</span> <span class="tx__role tx__role--coder">[coder]</span> <span class="tx__msg">emit @article/@inproceedings from pubs/*.bib.</span></span>
            <span class="tx__line"><span class="tx__t">[t+0.63s][a03]</span> <span class="tx__role tx__role--tester">[tester]</span> <span class="tx__msg"><span class="ok">✓</span> {{ pubs | size | default: 6 }}/6 publications cited; keys unique.</span></span>
            <span class="tx__line"><span class="tx__t">[t+0.69s][a04]</span> <span class="tx__role tx__role--reviewer">[reviewer]</span> <span class="tx__msg">no invented entries; matches _content.md §publications.</span></span>
            <span class="tx__stamp">approved</span>
          </aside>
          <div class="con">
            <div class="section__head">
              <span class="section__nav"><span class="ps1">&gt; aura_lab ::</span> <span class="cmd">bibtex</span> <span class="arg">--selected pubs/*.bib</span></span>
              <span class="section__tag">// 03 — selected publications</span>
            </div>
            <h2 class="h2" id="pubs-h">Selected Publications</h2>
            <div class="bib">
              {% for p in pubs %}
<pre class="bib__entry"><span class="bib__open">@{{ p.type | default: "inproceedings" }}{</span><span class="bib__key">{{ p.key }}</span>,
  <span class="bib__field">author</span>    = <span class="bib__val">{ {{- p.authors -}} }</span>,
  <span class="bib__field">title</span>     = <span class="bib__val">{ {{- p.title -}} }</span>,
  <span class="bib__field">booktitle</span> = <span class="bib__val">{ {{- p.venue -}} }</span>,
  <span class="bib__field">year</span>      = <span class="bib__val">{ {{- p.year -}} }</span>
<span class="bib__close">}</span></pre>
              {% endfor %}
            </div>
          </div>
        </article>

        {%- comment -%} ───── 04 PEOPLE ───── {%- endcomment -%}
        {% assign students = site.data.lab.students %}
        {% assign collabs  = site.data.lab.collaborators %}
        {% assign people_n = students | size | plus: 1 %}
        <article class="loop" id="loop-people" role="listitem">
          <aside class="tx" aria-label="Agent transcript: members">
            <div class="tx__head">// loop 04 · agents.log</div>
            <span class="tx__line"><span class="tx__t">[t+0.74s][a01]</span> <span class="tx__role tx__role--planner">[planner]</span> <span class="tx__msg">plan(people): director + phd students + collaborators.</span></span>
            <span class="tx__line"><span class="tx__t">[t+0.81s][a02]</span> <span class="tx__role tx__role--coder">[coder]</span> <span class="tx__msg">emit ls -la rows.</span></span>
            <span class="tx__line"><span class="tx__t">[t+0.88s][a03]</span> <span class="tx__role tx__role--tester">[tester]</span> <span class="tx__msg"><span class="ok">✓</span> {{ people_n }}/{{ people_n }} members listed; {{ collabs | size }}/{{ collabs | size }} collaborators.</span></span>
            <span class="tx__line"><span class="tx__t">[t+0.93s][a04]</span> <span class="tx__role tx__role--reviewer">[reviewer]</span> <span class="tx__msg">join dates surfaced where canonical; placeholders otherwise.</span></span>
            <span class="tx__stamp">approved</span>
          </aside>
          <div class="con">
            <div class="section__head">
              <span class="section__nav"><span class="ps1">&gt; aura_lab ::</span> <span class="cmd">ls -la</span> <span class="arg">members/</span></span>
              <span class="section__tag">// 04 — people</span>
            </div>
            <h2 class="h2" id="people-h">Members</h2>
            <div class="ls" role="table" aria-label="Lab members directory listing">
              <div class="ls__total">total 12 · drwxr-xr-x  aura_lab  staff</div>
              <div class="ls__row ls__row--head" role="row">
                <span>perms</span><span>n</span><span>role</span><span>name</span><span>joined</span>
              </div>
              <div class="ls__group">// director</div>
              <div class="ls__row" role="row">
                <span class="ls__perm">drwxr-xr-x</span><span class="ls__n">1</span>
                <span class="ls__role">director</span>
                <span class="ls__name">antonio_mastropaolo — Asst. Prof.; PhD USI '24</span>
                <span class="ls__date">2024-09-01</span>
              </div>
              <div class="ls__group">// phd students</div>
              {% for s in students %}
                <div class="ls__row" role="row">
                  <span class="ls__perm">-rw-r--r--</span><span class="ls__n">1</span>
                  <span class="ls__role">phd_student</span>
                  <span class="ls__name">{{ s.handle }}</span>
                  <span class="ls__date">{{ s.joined | default: "----------" }}</span>
                </div>
              {% endfor %}
            </div>
            <div class="ls__group" style="margin-top:18px;">// collaborators — frequent co-authors</div>
            <ul class="collab" aria-label="Collaborators">
              {% for c in collabs %}<li>{{ c }}</li>{% endfor %}
            </ul>
          </div>
        </article>

        {%- comment -%} ───── 05 NEWS ───── {%- endcomment -%}
        {% assign news = site.data.lab.news %}
        <article class="loop" id="loop-news" role="listitem">
          <aside class="tx" aria-label="Agent transcript: news">
            <div class="tx__head">// loop 05 · agents.log</div>
            <span class="tx__line"><span class="tx__t">[t+0.99s][a01]</span> <span class="tx__role tx__role--planner">[planner]</span> <span class="tx__msg">plan(news): git-log; reverse-chrono.</span></span>
            <span class="tx__line"><span class="tx__t">[t+1.05s][a02]</span> <span class="tx__role tx__role--coder">[coder]</span> <span class="tx__msg">emit rows.</span></span>
            <span class="tx__line"><span class="tx__t">[t+1.12s][a03]</span> <span class="tx__role tx__role--tester">[tester]</span> <span class="tx__msg"><span class="ok">✓</span> {{ news | size | default: 4 }}/{{ news | size | default: 4 }} news items; ordering monotonic.</span></span>
            <span class="tx__line"><span class="tx__t">[t+1.18s][a04]</span> <span class="tx__role tx__role--reviewer">[reviewer]</span> <span class="tx__msg">end of file; pipeline drained; lock released.</span></span>
            <span class="tx__stamp">approved</span>
          </aside>
          <div class="con">
            <div class="section__head">
              <span class="section__nav"><span class="ps1">&gt; aura_lab ::</span> <span class="cmd">git log</span> <span class="arg">--oneline news/</span></span>
              <span class="section__tag">// 05 — news</span>
            </div>
            <h2 class="h2" id="news-h">Activity Log</h2>
            <ol class="gitlog">
              {% for n in news %}
                <li class="gitlog__row">
                  <span class="gitlog__hash">{{ n.hash }}</span>
                  <span class="gitlog__date">{{ n.date }}</span>
                  <span class="gitlog__msg">
                    {% if forloop.first %}<span class="gitlog__head">HEAD → main</span>{% endif %}
                    {{ n.message }}
                  </span>
                </li>
              {% endfor %}
            </ol>
          </div>
        </article>

      </div><!-- /.stack -->

      {{ content }}

      <div class="prompt" style="margin-top:24px;">
        <span class="ps1">aura-se-lab:~/$</span>
        <span class="cmd">contact</span>
        <span class="arg">--mail</span>
      </div>
      <div class="sig">
        <div>
          mailto: <a href="mailto:amastropaolo@wm.edu">amastropaolo@wm.edu</a>
          · web: <a href="https://aura-se-lab.github.io">aura-se-lab.github.io</a>
        </div>
        <div class="sig__hint">// end of file — pipeline t+1.18s</div>
      </div>

    </div>
  </section>
</main>
