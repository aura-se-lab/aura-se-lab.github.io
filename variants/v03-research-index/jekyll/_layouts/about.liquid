---
# v03 Research Index — drop-in replacement for _layouts/about.liquid
layout: default
---

<div class="v03-shell">

  <header class="v03-topbar">
    <div class="mark">
      <span class="glyph">A</span>
      <span>{{ site.title | default: "AURA Lab" }}</span>
    </div>
    <nav>
      <a class="active" href="{{ '/' | relative_url }}">Index</a>
      <a href="{{ '/publications/' | relative_url }}">Publications</a>
      <a href="#avenues">Research</a>
      <a href="#people">People</a>
      <a href="{{ '/news/' | relative_url }}">News</a>
    </nav>
  </header>

  <section class="v03-masthead">
    <div>
      <h1 class="lab-name">The <span class="acro-letter">A</span><span class="acro-letter">U</span><span class="acro-letter">R</span><span class="acro-letter">A</span> Lab</h1>
      <p class="agenda">
        <span class="acro-letter">A</span>I for
        <span class="acro-letter">U</span>nderstandable and
        <span class="acro-letter">R</span>esponsible
        <span class="acro-letter">A</span>utomation in Software Engineering.
      </p>
      <div class="director">
        <span>Director</span><span class="dot"></span>
        <strong>Antonio Mastropaolo</strong>
        <span class="dot"></span>
        <span>William &amp; Mary, Department of Computer Science</span>
      </div>
    </div>
    <aside class="sidemeta">
      <div class="row"><span class="k">Founded</span><span class="v">Fall 2024</span></div>
      <div class="row"><span class="k">Institution</span><span class="v">William &amp; Mary</span></div>
      <div class="row"><span class="k">Avenues</span><span class="v">04 + 01</span></div>
      <div class="row"><span class="k">Contact</span><span class="v">amastropaolo<span class="muted"> at </span>wm<span class="muted"> dot </span>edu</span></div>
      <div class="row"><span class="k">Director site</span><span class="v"><a href="https://antoniomastropaolo.com">antoniomastropaolo.com</a></span></div>
    </aside>
  </section>

  <!-- Lab statement (renders {{ content }} from about.md so editors can tweak) -->
  {% if content and content != "" %}
    <section class="v03-statement clearfix">
      {{ content }}
    </section>
  {% endif %}

  <!-- Publications -->
  <section class="v03-block" id="publications">
    <div class="v03-section-head">
      <div>
        <div class="label">01 / Index</div>
        <h2><a href="{{ '/publications/' | relative_url }}" style="color:inherit">Selected publications</a></h2>
      </div>
      <div class="meta">06 papers · 2024–2025</div>
    </div>

    <div class="v03-pubs">
      {% assign pubs = site.data.v03_publications | default: nil %}
      {% if pubs %}
        {% for p in pubs %}
          <article class="pub">
            <div class="venue"><span>{{ p.venue }}</span><span class="year">{{ p.year }}</span></div>
            <h3 class="pub-title">{{ p.title }}</h3>
            <div class="authors">{{ p.authors }}</div>
            <div class="chips">
              {% for c in p.chips %}<span class="chip{% if c.accent %} accent{% endif %}">{{ c.label }}</span>{% endfor %}
            </div>
            <span class="arrow">↗</span>
          </article>
        {% endfor %}
      {% else %}
        <article class="pub"><div class="venue"><span>TOSEM</span><span class="year">2024</span></div><h3 class="pub-title">From Triumph to Uncertainty: The Journey of Software Engineering in the AI Era</h3><div class="authors">Mastropaolo, A.; Escobar-Velásquez, C.; Linares-Vásquez, M.</div><div class="chips"><span class="chip accent">Survey</span><span class="chip">AI for SE</span></div><span class="arrow">↗</span></article>
        <article class="pub"><div class="venue"><span>ICPC</span><span class="year">2025</span></div><h3 class="pub-title">Optimizing Datasets for Code Summarization: Is Code-Comment Coherence Enough?</h3><div class="authors">Vitale, A.; Mastropaolo, A.; Oliveto, R.; Di Penta, M.; Scalabrino, S.</div><div class="chips"><span class="chip">Summarization</span><span class="chip">Datasets</span></div><span class="arrow">↗</span></article>
        <article class="pub"><div class="venue"><span>FORGE</span><span class="year">2025</span></div><h3 class="pub-title">Resource-Efficient &amp; Effective Code Summarization</h3><div class="authors">Afrin, S.; Call, J.; Nguyen, K.-N.; Chaparro, O.; Mastropaolo, A.</div><div class="chips"><span class="chip accent">Efficiency</span><span class="chip">Summarization</span></div><span class="arrow">↗</span></article>
        <article class="pub"><div class="venue"><span>ICPC ERA</span><span class="year">2025</span></div><h3 class="pub-title">Toward Neurosymbolic Program Comprehension</h3><div class="authors">Velasco, A.; Garryyeva, A.; Palacio, D. N.; Mastropaolo, A.; Poshyvanyk, D.</div><div class="chips"><span class="chip accent">Neurosymbolic</span><span class="chip">Comprehension</span></div><span class="arrow">↗</span></article>
        <article class="pub"><div class="venue"><span>ICSME</span><span class="year">2025</span></div><h3 class="pub-title">Is Quantization a Deal-breaker? Empirical Insights from Large Code Models</h3><div class="authors">Afrin, S.; Xu, B.; Mastropaolo, A.</div><div class="chips"><span class="chip accent">Efficiency</span><span class="chip">Quantization</span><span class="chip">Empirical</span></div><span class="arrow">↗</span></article>
        <article class="pub"><div class="venue"><span>FSE Ideas</span><span class="year">2025</span></div><h3 class="pub-title">A Path Less Traveled: Reimagining Software Engineering Automation via a Neurosymbolic Paradigm</h3><div class="authors">Mastropaolo, A.; Poshyvanyk, D.</div><div class="chips"><span class="chip accent">Neurosymbolic</span><span class="chip">Vision</span></div><span class="arrow">↗</span></article>
      {% endif %}
    </div>

    {% if page.selected_papers %}
      <div style="margin-top:24px">{% include selected_papers.liquid %}</div>
    {% endif %}
  </section>

  <!-- Avenues -->
  <section class="v03-block" id="avenues">
    <div class="v03-section-head">
      <div>
        <div class="label">02 / Index</div>
        <h2>Research avenues</h2>
      </div>
      <div class="meta">04 primary · 01 supporting</div>
    </div>

    <div class="v03-avenues">
      <article class="avenue">
        <div class="av-label"><span class="num">01</span><span>/ Explainability</span></div>
        <h3>Explainability &amp; Interpretability</h3>
        <p>Methods that reveal how code models reason — rationales, traces, tests — so developers can inspect, trust, and debug automation.</p>
        <span class="av-arrow">→</span>
      </article>
      <article class="avenue">
        <div class="av-label"><span class="num">02</span><span>/ Efficiency</span></div>
        <h3>Efficiency &amp; Resource-Aware Automation</h3>
        <p>Quantization, distillation, and PEFT to deliver low-latency, memory-light, cost-aware automation on real workloads with reproducible metrics.</p>
        <span class="av-arrow">→</span>
      </article>
      <article class="avenue">
        <div class="av-label"><span class="num">03</span><span>/ Multi-Agent</span></div>
        <h3>Multi-Agent LLMs for SE</h3>
        <p>Role-aligned agents that plan, code, test, and review — coordinated to produce coherent, end-to-end developer assistance.</p>
        <span class="av-arrow">→</span>
      </article>
      <article class="avenue">
        <div class="av-label"><span class="num">04</span><span>/ Neurosymbolic</span></div>
        <h3>Neurosymbolic AI for SE</h3>
        <p>Hybrid pipelines pairing LLMs with program analysis and constraints to produce interpretable, checkable fixes, tests, and designs.</p>
        <span class="av-arrow">→</span>
      </article>
    </div>

    <div class="avenue-secondary">
      <div class="av-label"><span class="num">05</span><span>/ Supporting</span></div>
      <h3>Task-Aware Code Automation</h3>
      <p>From issues, diffs, and traces to concise summaries, TODOs, and plans — models that reduce developer toil with actionable, repo-aware guidance.</p>
    </div>
  </section>

  <div class="v03-bottom-grid">

    <section class="v03-block v03-people" id="people">
      <div class="v03-section-head">
        <div>
          <div class="label">03 / Index</div>
          <h2>People</h2>
        </div>
        <div class="meta">01 director · 07 students</div>
      </div>

      <div class="director-card">
        <div class="mono-square">AM</div>
        <div class="who">
          <span class="name">Antonio Mastropaolo</span>
          <span class="role">Director · Assistant Professor</span>
          <span class="bio">Ph.D., Università della Svizzera Italiana (2024). M.Sc. / B.Sc., University of Molise.</span>
        </div>
      </div>

      <div class="people-grid">
        <div class="person"><div class="mono-square">SA</div><div class="meta"><span class="pname">Saima Afrin</span><span class="pmeta">PhD · Sep 2024</span></div></div>
        <div class="person"><div class="mono-square">AG</div><div class="meta"><span class="pname">Aya Garryyeva</span><span class="pmeta">PhD · Jan 2025</span></div></div>
        <div class="person"><div class="mono-square">JC</div><div class="meta"><span class="pname">Joseph Call</span><span class="pmeta">PhD · Jan 2025</span></div></div>
        <div class="person"><div class="mono-square">KN</div><div class="meta"><span class="pname">Khai-Nguyen Nguyen</span><span class="pmeta">PhD Student</span></div></div>
        <div class="person"><div class="mono-square">AL</div><div class="meta"><span class="pname">Alvi</span><span class="pmeta">Student</span></div></div>
        <div class="person"><div class="mono-square">BE</div><div class="meta"><span class="pname">Ben</span><span class="pmeta">Student</span></div></div>
        <div class="person"><div class="mono-square">CH</div><div class="meta"><span class="pname">Chris</span><span class="pmeta">Student</span></div></div>
      </div>

      <div class="collaborators">
        <div class="label">Frequent collaborators</div>
        <div class="collab-list">
          <span class="collab">Denys Poshyvanyk · W&amp;M</span>
          <span class="collab">David Nader Palacio</span>
          <span class="collab">Alejandro Velasco</span>
          <span class="collab">Oscar Chaparro</span>
          <span class="collab">Bowen Xu</span>
        </div>
      </div>
    </section>

    <aside class="v03-block v03-news" id="news">
      <div class="v03-section-head">
        <div>
          <div class="label">04 / Index</div>
          <h2><a href="{{ '/news/' | relative_url }}" style="color:inherit">News</a></h2>
        </div>
        <div class="meta">Recent</div>
      </div>

      {% if page.news and site.announcements.enabled %}
        {% include news.liquid limit=true %}
      {% else %}
        <div class="news-item"><div class="when">2024 · 12</div><div class="what"><em>From Triumph to Uncertainty</em> accepted to TOSEM.</div></div>
        <div class="news-item"><div class="when">2025 · 01</div><div class="what">Welcome to <em>Aya Garryyeva</em> and <em>Joseph Call</em>, joining the AURA Lab.</div></div>
        <div class="news-item"><div class="when">2024 · 11</div><div class="what">Announced January arrivals: <em>Aya</em> and <em>Joseph</em>.</div></div>
        <div class="news-item"><div class="when">2024 · 09</div><div class="what">Welcome to <em>Saima Afrin</em>, joining the AURA Lab.</div></div>
      {% endif %}
    </aside>

  </div>

  {% if page.social %}
    <div class="v03-social">
      <div class="contact-icons">{% include social.liquid %}</div>
      <div class="contact-note">{{ site.contact_note }}</div>
    </div>
  {% endif %}

  <footer class="v03-foot">
    <div>© {{ site.time | date: '%Y' }} AURA Lab · William &amp; Mary</div>
    <div>aura-se-lab.github.io</div>
    <div>amastropaolo · wm · edu</div>
  </footer>

</div>
