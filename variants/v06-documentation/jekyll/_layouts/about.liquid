<script>
  (function () {
    var hb = document.getElementById('v06-hamburger');
    var sb = document.getElementById('v06-sidebar');
    if (hb && sb) {
      hb.addEventListener('click', function () { sb.classList.toggle('open'); });
      sb.addEventListener('click', function (e) {
        if (e.target.tagName === 'A') sb.classList.remove('open');
      });
    }
    var rail = document.getElementById('v06-rail-list');
    if (rail && 'IntersectionObserver' in window) {
      var links = Array.prototype.slice.call(rail.querySelectorAll('a'));
      var idMap = {};
      links.forEach(function (a) {
        var id = a.getAttribute('href').slice(1);
        var el = document.getElementById(id);
        if (el) idMap[id] = a;
      });
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            links.forEach(function (a) { a.classList.remove('active'); });
            var a = idMap[e.target.id];
            if (a) a.classList.add('active');
          }
        });
      }, { rootMargin: '-72px 0px -70% 0px', threshold: 0 });
      Object.keys(idMap).forEach(function (id) {
        observer.observe(document.getElementById(id));
      });
    }
  })();
</script>
